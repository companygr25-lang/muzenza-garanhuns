rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVE HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- VALIDATION BLUEPRINTS ---
    
    function isValidUser(data) {
      return data.username is string && data.username.size() >= 1 && data.username.size() <= 50
        && data.role in ['admin', 'user']
        && data.status in ['active', 'inactive']
        && data.monthlyPaid is bool
        && (data.get('phone', '') is string)
        && (data.get('createdAt', '') is string);
    }

    function isValidEvent(data) {
      return data.title is string && data.title.size() >= 1 && data.title.size() <= 200
        && data.date is string
        && (data.get('location', '') is string)
        && (data.get('description', '') is string);
    }

    function isValidRegistration(data) {
      return isValidId(data.eventId)
        && data.userId == request.auth.uid
        && data.status in ['pending', 'approved']
        && data.paymentStatus in ['pending', 'paid'];
    }

    function isValidOrder(data) {
      return isValidId(data.itemId)
        && data.userId == request.auth.uid
        && data.quantity is int && data.quantity > 0
        && data.status in ['pending', 'confirmed', 'delivered']
        && data.paymentStatus in ['pending', 'paid'];
    }

    // --- COLLECTION MATCHES ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming())
        && incoming().role == 'user'; // Users can only create 'user' role profiles
      allow update: if isAdmin() || (isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['phone', 'username']));
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() && isValidEvent(incoming());
      allow update: if isAdmin() && isValidEvent(incoming());
      allow delete: if isAdmin();
    }

    match /registrations/{registrationId} {
      allow read: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow create: if isSignedIn() && isValidRegistration(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /store_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /store_orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /config/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system/{document=**} {
      allow read: if true;
    }
  }
}
